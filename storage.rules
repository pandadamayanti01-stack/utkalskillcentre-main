rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow users to upload and view their own monthly test evidence
    match /monthly_test_evidence/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow users to upload their profile pictures
    match /profile_pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow reading and writing of textbook chapter PDFs (reads are public, writes restricted to authenticated admins)
    match /chapters_pdf/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'pandadamayanti01@gmail.com' ||
        request.auth.token.phone_number == '+919337956168' ||
        request.auth.token.phone_number == '9337956168'
      );
    }

    // Default deny for everything else (or fallback to authenticated)
    match /{allPaths=**} {
      allow read: if true; // Just in case there are public assets
      allow write: if false;
    }
  }
}
