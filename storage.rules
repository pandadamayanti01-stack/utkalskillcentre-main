rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow users to upload and view their own monthly test evidence
    match /monthly_test_evidence/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow write: if request.auth != null && 
                    request.auth.uid == userId &&
                    request.resource.size < 10 * 1024 * 1024 && // 10MB Max
                    request.resource.contentType.matches('image/.*'); // Images only
    }
    
    // Allow users to upload their profile pictures
    match /profile_pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
                    request.auth.uid == userId &&
                    request.resource.size < 5 * 1024 * 1024 && // 5MB Max
                    request.resource.contentType.matches('image/.*'); // Images only
    }

    // Allow reading and writing of textbook chapter PDFs (reads are public, writes restricted to authenticated admins)
    match /chapters_pdf/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'pandadamayanti01@gmail.com' ||
        request.auth.token.phone_number == '+919337956168' ||
        request.auth.token.phone_number == '9337956168'
      );
    }

    // Allow reading and writing of textbook chapter covers (reads are public, writes restricted to authenticated admins)
    match /chapters_covers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && (
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'pandadamayanti01@gmail.com' ||
        request.auth.token.phone_number == '+919337956168' ||
        request.auth.token.phone_number == '9337956168'
      );
    }

    // Allow reading and writing of community files (isolated by userId to prevent overwriting)
    match /community_files/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
                    request.auth.uid == userId &&
                    request.resource.size < 10 * 1024 * 1024 && // 10MB Max
                    (request.resource.contentType.matches('image/.*') || 
                     request.resource.contentType.matches('application/pdf') || 
                     request.resource.contentType.matches('audio/.*'));
    }

    // Default deny for everything else (Strict security default)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
